MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bandmerch?retryWrites=true&w=majority
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
PORT=5000
NODE_ENV=development

# --- Payment processing (Phase 6) ---
# Stripe Dashboard (TEST mode) -> Developers -> API keys -> Secret key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# Stripe Dashboard -> Developers -> Webhooks -> signing secret for the registered endpoint
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-signing-secret
# PayPal Developer Dashboard -> Apps & Credentials -> Sandbox -> your app -> Client ID
PAYPAL_CLIENT_ID=your-paypal-sandbox-client-id
# same app -> Secret
PAYPAL_CLIENT_SECRET=your-paypal-sandbox-client-secret
# PayPal Developer Dashboard -> Webhooks -> webhook id for the registered endpoint
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id
# sandbox|live -- default sandbox per D-19 (test/verify before go-live)
PAYPAL_ENV=sandbox

# --- Transactional email (Phase 6, D-12) ---
# Resend Dashboard -> API Keys
RESEND_API_KEY=re_your-resend-api-key
# Band inbox that receives the internal "new paid order" notification (D-13)
BAND_NOTIFICATION_EMAIL=orders@hurakanband.fr

# --- Web origin (Phase 6) ---
# Used to build Stripe success/cancel and PayPal return/cancel redirect URLs
WEB_BASE_URL=https://hurakanband.fr
