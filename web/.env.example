# Bandsintown artist API key (obtained via Bandsintown for Artists →
# Settings → General → Get API Key). Used ONLY at build time by
# web/src/lib/bandsintown.ts to fetch upcoming concerts and bake them into
# the static HTML.
#
# IMPORTANT: This variable MUST NOT be VITE_-prefixed. A VITE_ prefix would
# inline the value into the shipped client JS bundle, leaking the key to the
# browser (D-09). It is read as process.env.BANDSINTOWN_APP_ID during the
# build (locally, and as a build-scope env var on Vercel).
BANDSINTOWN_APP_ID=
