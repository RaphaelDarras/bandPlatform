{
  "expo": {
    "name": "Hurakan Merch",
    "slug": "band-pos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/hurakan_slam_white_transparent.png",
    "scheme": "bandpos",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a1a",
        "foregroundImage": "./assets/images/hurakan_slam_white_transparent.png",
        "monochromeImage": "./assets/images/hurakan_slam_white_transparent.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.bandpos"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      "expo-image",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b5f2a277-9e4d-4ef5-b44d-6b34a831f899"
      }
    },
    "owner": "raphaeldarras"
  }
}
